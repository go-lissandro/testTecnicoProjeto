# ============================================================
# Onda Finance — Environment Variables
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env com valores reais.
# ============================================================

# URL base da API (mock para desenvolvimento)
VITE_API_URL=https://api.ondafinance.mock

# Ambiente da aplicação
VITE_APP_ENV=development

# Versão (gerada no CI/CD)
VITE_APP_VERSION=1.0.0

# Feature flags
VITE_FEATURE_DEFI=false
VITE_FEATURE_MARKETS=false
